---
import { certifications } from '../data/certifications';

const badgeColors: Record<string, string> = {
  gcp: 'from-blue-500/20 to-blue-600/10 text-blue-400',
  aws: 'from-orange-500/20 to-orange-600/10 text-orange-400',
  cncf: 'from-cyan-500/20 to-cyan-600/10 text-cyan-400',
  hashicorp: 'from-purple-500/20 to-purple-600/10 text-purple-400',
};
---

<section id="certifications" class="section-container">
  <h2 class="section-title">Certifications</h2>
  <div class="grid gap-4 sm:grid-cols-2">
    {
      certifications.map((cert) => (
        <article class="card flex flex-col">
          <div
            class={`mb-4 inline-flex w-fit rounded-lg bg-gradient-to-br px-3 py-1 text-xs font-semibold uppercase tracking-wider ${badgeColors[cert.badge ?? 'gcp']}`}
          >
            {cert.issuer}
          </div>
          <h3 class="mb-2 font-semibold leading-snug text-white">{cert.name}</h3>
          <p class="mb-1 text-sm text-gray-500">
            Issued {cert.issued} &middot; Expires {cert.expires}
          </p>
          <a
            href={`${import.meta.env.BASE_URL}${cert.pdf}`}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto pt-4 text-sm font-medium text-accent transition-colors hover:text-accent-hover"
          >
            View certificate &rarr;
          </a>
        </article>
      ))
    }
  </div>
</section>
